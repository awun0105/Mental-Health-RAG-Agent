# ==========================================
# 1. Môi trường & Biến bảo mật (SỐNG CÒN)
# ==========================================
.venv/
.env
.env.*
!.env.example
.archive
# ==========================================
# 2. Bộ nhớ đệm (Cache) của Python & Công cụ
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# ==========================================
# 3. Notebooks (Vì bạn có thư mục notebooks/)
# ==========================================
.ipynb_checkpoints/

# ==========================================
# 4. Thư mục cá nhân & Tài liệu nháp
# ==========================================
_notes/*.backup
_notes/temp_*.md
*.md.backup

# ==========================================
# 5. Hệ điều hành & IDE (Code Editor)
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/
.cursorignore
.cursorindexingignore

# ==========================================
# 6. Dữ liệu (Tránh đẩy file PDF, DB nặng lên Git)
# ==========================================
backend/data/raw/*
backend/data/processed/*
!backend/data/raw/.gitkeep
!backend/data/processed/.gitkeep

GEMINI.md
MASTER_PLAN.md
